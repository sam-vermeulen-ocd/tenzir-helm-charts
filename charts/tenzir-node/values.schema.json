{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "token"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "config": {
            "type": "object",
            "additionalProperties": true
          },
          "extraPorts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "containerPort"],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
                  "maxLength": 15
                },
                "containerPort": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                },
                "servicePort": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                },
                "serviceType": {
                  "type": "string",
                  "enum": ["", "ClusterIP", "NodePort", "LoadBalancer"]
                },
                "protocol": {
                  "type": "string",
                  "enum": ["TCP", "UDP", "SCTP"]
                },
                "annotations": {
                  "type": "object"
                }
              }
            }
          },
          "token": {
            "type": "object",
            "properties": {
              "value": {
                "type": "string"
              },
              "existingSecret": {
                "type": "string"
              },
              "key": {
                "type": "string",
                "minLength": 1
              }
            },
            "anyOf": [
              {
                "properties": {
                  "value": { "type": "string", "minLength": 1 }
                },
                "required": ["value"]
              },
              {
                "properties": {
                  "existingSecret": { "type": "string", "minLength": 1 }
                },
                "required": ["existingSecret"]
              }
            ]
          }
        }
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "registry": {
          "type": "string"
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "allowSameNamespace": { "type": "boolean" },
        "ingress": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "annotations": {
          "type": "object"
        }
      }
    },
    "tenzir": {
      "type": "object",
      "properties": {
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "sharedServices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "port"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
            "maxLength": 30
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "targetPort": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "type": {
            "type": "string",
            "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
          },
          "protocol": {
            "type": "string",
            "enum": ["TCP", "UDP", "SCTP"]
          },
          "nodes": {
            "oneOf": [
              { "type": "string", "enum": ["all"] },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "annotations": {
            "type": "object"
          }
        }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^[0-9]+%$" }
          ]
        },
        "maxUnavailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^[0-9]+%$" }
          ]
        }
      }
    },
    "persistence": {
      "$ref": "#/definitions/persistence"
    },
    "readinessProbe": {
      "$ref": "#/definitions/probe"
    },
    "livenessProbe": {
      "$ref": "#/definitions/probe"
    }
  },
  "definitions": {
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        },
        "accessModes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "storageClass": {
          "type": "string"
        },
        "annotations": {
          "type": "object"
        },
        "existingClaim": {
          "type": "string"
        }
      }
    },
    "probe": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
